{
    "definition": {
        "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
        "contentVersion": "1.0.0.0",
        "parameters": {
            "$connections": {
                "defaultValue": {},
                "type": "Object"
            },
            "DevOps_Org": {
                "type": "string",
                "defaultValue": "REPLACE_YOUR_ORG_NAME"
            },
            "DevOps_Project": {
                "type": "string",
                "defaultValue": "REPLACE_YOUR_PROJECT_NAME"
            },
            "DevOps_PAT": {
                "type": "securestring",
                "defaultValue": "REPLACE_YOUR_PAT_TOKEN"
            },
            "DocIntel_Endpoint": {
                "type": "string",
                "defaultValue": "REPLACE_https://YOUR_INSTANCE.cognitiveservices.azure.com"
            },
            "DocIntel_Key": {
                "type": "securestring",
                "defaultValue": "REPLACE_YOUR_DOCUMENT_INTELLIGENCE_KEY"
            }
        },
        "triggers": {
            "manual": {
                "type": "Request",
                "kind": "Http",
                "inputs": {
                    "schema": {
                        "type": "object",
                        "properties": {
                            "workItemId": {
                                "type": "integer",
                                "description": "The DevOps work item ID to process."
                            }
                        },
                        "required": [ "workItemId" ]
                    }
                }
            }
        },
        "actions": {
            "1_Get_Attachments": {
                "type": "Http",
                "runAfter": {},
                "inputs": {
                    "method": "GET",
                    "uri": "@{concat('https://dev.azure.com/', parameters('DevOps_Org'), '/', parameters('DevOps_Project'), '/_apis/wit/workitems/', triggerBody()?['workItemId'], '/attachments?api-version=7.1-preview.1')}",
                    "headers": {
                        "Authorization": "@{concat('Basic ', base64(concat(':', parameters('DevOps_PAT'))))}"
                    }
                }
            },
            "2_Download_PDF": {
                "type": "Http",
                "runAfter": {
                    "1_Get_Attachments": [ "Succeeded" ]
                },
                "inputs": {
                    "method": "GET",
                    "uri": "@{body('1_Get_Attachments')?['value'][0]['url']}",
                    "headers": {
                        "Authorization": "@{concat('Basic ', base64(concat(':', parameters('DevOps_PAT'))))}"
                    }
                }
            },
            "3_Submit_To_Document_Intelligence": {
                "type": "Http",
                "runAfter": {
                    "2_Download_PDF": [ "Succeeded" ]
                },
                "inputs": {
                    "method": "POST",
                    "uri": "@{concat(parameters('DocIntel_Endpoint'), '/formrecognizer/documentModels/prebuilt-document:analyze?api-version=2023-07-31')}",
                    "headers": {
                        "Ocp-Apim-Subscription-Key": "@parameters('DocIntel_Key')",
                        "Content-Type": "application/pdf"
                    },
                    "body": "@body('2_Download_PDF')"
                }
            },
            "4_Get_Analysis_Result": {
                "type": "Http",
                "runAfter": {
                    "3_Submit_To_Document_Intelligence": [ "Succeeded" ]
                },
                "inputs": {
                    "method": "GET",
                    "uri": "@{outputs('3_Submit_To_Document_Intelligence')?['headers']?['Operation-Location']}",
                    "headers": {
                        "Ocp-Apim-Subscription-Key": "@parameters('DocIntel_Key')"
                    }
                }
            },
            "5_Return_Result": {
                "type": "Response",
                "runAfter": {
                    "4_Get_Analysis_Result": [ "Succeeded" ]
                },
                "inputs": {
                    "statusCode": 200,
                    "headers": {
                        "Content-Type": "application/json"
                    },
                    "body": "@body('4_Get_Analysis_Result')"
                }
            }
        },
        "outputs": {}
    },
    "parameters": {
        "$connections": {
            "value": {}
        }
    }
}
